# SOCVault — Environment reference (one AWS account · staging / production)
# Secrets in SSM: /socvault/staging/* and /socvault/production/*
# See docs/19_CI_CD_AND_ENVIRONMENTS.md · ADR-006 (serverless MVP — no local runtime)

# ── Environment (set per deploy target) ──
APP_ENV=staging                    # staging | production
AWS_REGION=eu-west-2
AWS_ACCOUNT_ID=
AWS_SECRETS_PREFIX=/socvault/staging   # or /socvault/production

# ── Public URLs ──
# Staging (MVP — active):
API_PUBLIC_URL=https://api-staging.socvault.io
FRONTEND_URL=https://app-staging.socvault.io
CORS_ORIGINS=https://app-staging.socvault.io
# Production (dormant until cutover):
# API_PUBLIC_URL=https://api.socvault.io
# FRONTEND_URL=https://app.socvault.io
# CORS_ORIGINS=https://app.socvault.io

# ── Data (from SSM in each AWS account) ──
MONGODB_URI=ssm:/socvault/staging/mongodb/uri
SQS_SCAN_QUEUE_URL=ssm:/socvault/staging/sqs/scan-jobs-url
S3_ARTIFACTS_BUCKET=socvault-artifacts-staging
DYNAMODB_TELEMETRY_TABLE=socvault-staging-cost-telemetry
DYNAMODB_RATE_LIMITS_TABLE=socvault-staging-rate-limits

# ── Auth (Cognito per environment — ADR-003) ──
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=eu-west-2

# ── Anthropic (SSM) ──
ANTHROPIC_API_KEY=ssm:/socvault/staging/anthropic/api_key
CLAUDE_MODEL_REASONING=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001
CLAUDE_MODEL_L9=claude-opus-4-8

# ── Threat intel (SSM) ──
ABUSEIPDB_API_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=

# ── Stripe (Phase 2 — separate keys per env) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Deploy (serverless MVP) ──
DEPLOY_TARGET=serverless              # API Gateway + Lambda + Amplify + SQS

# ── Notifications ──
SLACK_WEBHOOK_URL=
SENDGRID_API_KEY=

# ── Wazuh (Phase 2+ — EC2 in same account) ──
WAZUH_MANAGER_URL=
WAZUH_API_USER=
WAZUH_API_PASSWORD=
