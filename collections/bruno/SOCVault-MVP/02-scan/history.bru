meta {
  name: Scan History
  type: http
  seq: 3
}

get {
  url: {{base_url}}/scan/history?layer=RECON&limit=20&offset=0
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("has items array", function() {
    expect(res.body.items).to.be.an("array");
  });
}
